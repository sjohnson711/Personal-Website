generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Article {
  id        Int       @id @default(autoincrement())
  title     String
  slug      String    @unique
  excerpt   String
  content   String
  published Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  comments  Comment[]
}

model Comment {
  id        Int      @id @default(autoincrement())
  articleId Int
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  name      String
  body      String
  createdAt DateTime @default(now())
}

model Admin {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
}

model Subscriber {
  id               Int      @id @default(autoincrement())
  email            String   @unique
  unsubscribeToken String   @unique
  createdAt        DateTime @default(now())
}

model EmbedCache {
  id          Int      @id @default(autoincrement())
  url         String   @unique
  type        String // 'card' | 'video'
  title       String?
  description String?
  image       String?
  provider    String?
  embedHtml   String?
  ok          Boolean  @default(true) // false = negative cache for failed/blocked fetches
  fetchedAt   DateTime @default(now())

  @@index([fetchedAt])
}
